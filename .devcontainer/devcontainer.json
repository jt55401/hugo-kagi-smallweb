{
  "name": "hugo-kagi-smallweb",
  "image": "mcr.microsoft.com/devcontainers/go:1-1.21-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/hugo:1": {
      "extended": true,
      "version": "latest"
    }
  },
  "postCreateCommand": "hugo version",
  "customizations": {
    "vscode": {
      "extensions": [
        "budparr.language-hugo-vscode",
        "golang.go"
      ]
    }
  },
  "remoteUser": "vscode"
}
